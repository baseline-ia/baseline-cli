#!/usr/bin/env bash
# baseline — pre-push hook
# 1. Blocks direct pushes to protected branches.
# 2. Validates that the branch is linked to a Jira ticket OR an SDD change.

PROTECTED=("main" "master" "qa" "develop")
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)

# --- 1. Block protected branches ---
for b in "${PROTECTED[@]}"; do
  if [[ "$BRANCH" == "$b" ]]; then
    echo ""
    echo "  baseline: direct push to '$BRANCH' is not allowed."
    echo ""
    echo "  Protected branches: ${PROTECTED[*]}"
    echo "  All changes must go through a pull request."
    echo ""
    echo "  Start from a Jira ticket or SDD change:"
    echo "    git checkout -b feat/PROJ-123-description     (with Jira)"
    echo "    git checkout -b feat/sdd-<change-id>-description  (without Jira)"
    echo ""
    echo "  Then open a PR with: /branch-pr"
    echo ""
    exit 1
  fi
done

# --- 2. Require Jira key or SDD id in branch name ---
HAS_JIRA=$(echo "$BRANCH" | grep -qE '[A-Z]+-[0-9]+' && echo "yes" || echo "no")
HAS_SDD=$(echo "$BRANCH"  | grep -qiE 'sdd-[a-z0-9-]+' && echo "yes" || echo "no")

if [[ "$HAS_JIRA" == "no" && "$HAS_SDD" == "no" ]]; then
  echo ""
  echo "  baseline: branch '$BRANCH' is not linked to any work item."
  echo ""
  echo "  Every branch must reference either:"
  echo "    feat/PROJ-123-description        ← Jira ticket key"
  echo "    feat/sdd-<change-id>-description ← SDD change (no Jira)"
  echo ""
  echo "  Rename your branch:"
  echo "    git branch -m feat/PROJ-123-description"
  echo ""
  exit 1
fi

exit 0
